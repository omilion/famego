rules_version = '2';
// Todo el acceso a los datos pasa por la Cloud Function `api`, que usa el
// SDK admin y no está sujeta a estas reglas. El acceso directo desde el
// cliente queda bloqueado.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
